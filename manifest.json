{
   "author": "vwvw",
   "background": {
      "scripts": [ "lib/jQuery/jquery.js", "js/lsmm.js", "js/egyptian.js", "background.js" ]
   },
   "browser_action": {
      "default_icon": {
         "128": "icon/icon128.png",
         "16": "icon/icon16.png",
         "48": "icon/icon48.png"
      }
   },
   "commands": {
      "write": {
         "description": "글 작성",
         "suggested_key": {
            "default": "Alt+S"
         }
      }
   },
   "content_scripts": [ {
      "css": [ "css/jquery-ui.min.css", "css/content.css" ],
      "js": [ "lib/jQuery/jquery.js", "lib/jQuery/jquery-ui.js", "content.js" ],
      "matches": [ "https://gall.dcinside.com/board/*", "https://gall.dcinside.com/mgallery/board/*", "https://gall.dcinside.com/mgallery//board/*" ],
      "run_at": "document_start"
   } ],
   "description": "디시인사이드 갤질을 위한 다양한 부가기능을 제공하는 익스텐션입니다.",
   "icons": {
      "128": "icon/icon128.png",
      "16": "icon/icon16.png",
      "48": "icon/icon48.png"
   },
   "key": "",
   "manifest_version": 2,
   "name": "DCSimpler",
   "options_page": "html/config.html",
   "permissions": [ "webRequest", "webRequestBlocking", "webNavigation", "activeTab", "https://gall.dcinside.com/board/*", "https://gall.dcinside.com/mgallery/board/*", "https://sites.google.com/view/dcsimpler/*", "https://ir.joins.com/*" ],
   "short_name": "dcsimpler",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.4.1",
   "web_accessible_resources": [ "*" ]
}
